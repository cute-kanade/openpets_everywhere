{
  "manifestVersion": 3,
  "id": "openpets.spotify-buddy",
  "name": "$t:plugin.name",
  "description": "$t:plugin.description",
  "version": "1.8.1",
  "runtime": "javascript",
  "icon": "sparkles",
  "sdkVersion": "3.0.0",
  "entry": "index.js",
  "permissions": [
    "network",
    "network:write",
    "schedule",
    "storage",
    "pet:speak",
    "pet:reaction",
    "commands",
    "status",
    "auth",
    "secrets",
    "ui:toast"
  ],
  "network": {
    "hosts": [
      "api.spotify.com",
      "accounts.spotify.com",
      "lrclib.net"
    ]
  },
  "configSchema": {
    "spotifyClientId": {
      "type": "text",
      "label": "Spotify Client ID",
      "default": "",
      "description": "Your Spotify App Client ID"
    },
    "pollIntervalSeconds": {
      "type": "number",
      "label": "Poll interval (seconds)",
      "default": 2,
      "min": 2,
      "max": 300,
      "step": 1
    },
    "announceTrackChanges": { "type": "boolean", "label": "Announce track changes", "default": true },
    "reactToMood": { "type": "boolean", "label": "React to track mood", "default": true },
    "reactWhenPaused": { "type": "boolean", "label": "React when paused", "default": true },
    "announceTemplate": {
      "type": "text",
      "label": "Announcement template",
      "default": "Now playing: {title} by {artist}",
      "maxLength": 140
    },
    "lyricAdvanceMs": {
      "type": "number",
      "label": "Lyric advance time (ms)",
      "default": 500,
      "min": 0,
      "max": 3000,
      "step": 100
    }
  }
}
