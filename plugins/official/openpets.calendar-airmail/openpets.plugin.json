    "courier-bear-balloon": { "path": "assets/couriers/courier-bear-balloon.webp", "frameWidth": 256, "frameHeight": 256, "frames": 8, "durationMs": 1200 }, "courier-pig-plane": { "path": "assets/couriers/courier-pig-plane.webp", "frameWidth": 256, "frameHeight": 256, "frames": 8, "durationMs": 1200 }, "courier-owl-scout": { "path": "assets/couriers/courier-owl-scout.webp", "frameWidth": 256, "frameHeight": 256, "frames": 8, "durationMs": 1200 }, "courier-firefly": { "path": "assets/couriers/courier-firefly.webp", "frameWidth": 256, "frameHeight": 256, "frames": 8, "durationMs": 1200 }, "courier-duck-glider": { "path": "assets/couriers/courier-duck-glider.webp", "frameWidth": 256, "frameHeight": 256, "frames": 8, "durationMs": 1200 }, "courier-dog-helicopter": { "path": "assets/couriers/courier-dog-helicopter.webp", "frameWidth": 256, "frameHeight": 256, "frames": 8, "durationMs": 1200 }, "courier-cat-balloon": { "path": "assets/couriers/courier-cat-balloon.webp", "frameWidth": 256, "frameHeight": 256, "frames": 8, "durationMs": 1200 }, "courier-pigeon": { "path": "assets/couriers/courier-pigeon.webp", "frameWidth": 256, "frameHeight": 256, "frames": 8, "durationMs": 1200 }
  } }
}
