    { "value": "courier-duck-glider", "label": "$t:config.courier.duck-glider", "previewSprite": "courier-duck-glider" },
    { "value": "courier-dog-helicopter", "label": "$t:config.courier.dog-helicopter", "previewSprite": "courier-dog-helicopter" },
    { "value": "courier-cat-balloon", "label": "$t:config.courier.cat-balloon", "previewSprite": "courier-cat-balloon" },
    { "value": "courier-pigeon", "label": "$t:config.courier.pigeon", "previewSprite": "courier-pigeon" }
  ] } },
  "assets": { "sprites": {
