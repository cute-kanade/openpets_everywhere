    { "value": "courier-dragon", "label": "$t:config.courier.dragon", "previewSprite": "courier-dragon" },
    { "value": "courier-cloud", "label": "$t:config.courier.cloud", "previewSprite": "courier-cloud" },
    { "value": "courier-bat", "label": "$t:config.courier.bat", "previewSprite": "courier-bat" },
    { "value": "courier-bee", "label": "$t:config.courier.bee", "previewSprite": "courier-bee" },
