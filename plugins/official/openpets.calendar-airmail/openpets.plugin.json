{
  "manifestVersion": 3, "id": "openpets.calendar-airmail", "name": "$t:plugin.name", "description": "$t:plugin.description", "version": "1.2.2", "runtime": "javascript", "icon": "bell", "sdkVersion": "3.0.0", "entry": "index.js",
  "permissions": ["ui:delivery", "auth", "network", "schedule", "storage", "commands", "status"], "network": { "hosts": ["www.googleapis.com"] },
